# FocusOS locked-down KWin config.
#
# Read via XDG_CONFIG_HOME (set by the session script). Disables the
# screen-edge / hot-corner actions and the overview/desktop-grid effects that
# would otherwise let the user summon a launcher or app picker by shoving the
# pointer into a corner. Window switching (Alt+Tab) is governed by
# kglobalshortcutsrc and stays enabled.

[TabBox]
# Alt+Tab walks through all open windows. Since only allowed apps are ever
# launched (others are killed by the lockdown watchdog), this is window
# switching restricted to the routine surface by construction.
ShowDesktopMode=0
SwitchingMode=0
LayoutName=org.kde.breeze.desktop

[Effect-overview]
BorderActivate=9
BorderActivateAll=9

# Disable every screen edge (1-8 = corners + edges). 0 = no action.
[ElectricBorders]
Bottom=None
BottomLeft=None
BottomRight=None
Left=None
Right=None
Top=None
TopLeft=None
TopRight=None

[ScreenEdges]
RemainActiveOnFullscreen=false

[Plugins]
overviewEnabled=false
desktopgridEnabled=false
windowviewEnabled=false
slideEnabled=true

[Windows]
# Focus-stealing prevention MUST be off here. FocusOS launches the routine apps
# itself (it is the active window at launch time), so any non-zero level makes
# KWin treat the new Brave / IDE / etc. windows as a foreign app stealing focus
# and refuses to raise or focus them — they map in the background and never come
# forward (you'd hear the app but never see it). This is NOT a security knob:
# *which* apps may run is enforced by the watchdog kill-list and the network
# gate, not by hiding their windows. 0 = None, let routine windows come up front.
FocusStealingPreventionLevel=0

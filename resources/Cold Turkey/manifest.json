{
   "action": {
      "default_icon": {
         "128": "icon128.png",
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon48.png"
      },
      "default_popup": "ctMenu.html"
   },
   "background": {
      "service_worker": "ctBackground.js"
   },
   "content_scripts": [ {
      "all_frames": true,
      "js": [ "ctContent.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_start"
   } ],
   "description": "This browser may be blocked if this extension is disabled or removed during a locked block.",
   "host_permissions": [ "*://getcoldturkey.com/*" ],
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "48": "icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Cold Turkey Blocker",
   "permissions": [ "nativeMessaging", "tabs", "idle", "storage", "notifications", "alarms" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.9.4",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "ctFrame.html", "ctFrame.js" ]
   } ]
}

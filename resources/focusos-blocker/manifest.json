{
   "manifest_version": 3,
   "name": "FocusOS Blocker",
   "version": "4.9.4",
   "description": "Enforces the FocusOS allow-list inside the browser during a focus session. Managed by FocusOS.",
   "key": "",
   "background": {
      "service_worker": "ctBackground.js"
   },
   "content_scripts": [
      {
         "all_frames": true,
         "js": [
            "ctContent.js"
         ],
         "matches": [
            "<all_urls>"
         ],
         "run_at": "document_start"
      }
   ],
   "permissions": [
      "nativeMessaging",
      "tabs",
      "idle",
      "storage",
      "notifications",
      "alarms"
   ],
   "host_permissions": [
      "<all_urls>"
   ],
   "action": {
      "default_icon": {
         "16": "icon16.png",
         "32": "icon32.png",
         "48": "icon48.png",
         "128": "icon128.png"
      },
      "default_popup": "ctMenu.html"
   },
   "icons": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
   },
   "web_accessible_resources": [
      {
         "matches": [
            "<all_urls>"
         ],
         "resources": [
            "blocked.html"
         ]
      }
   ]
}
